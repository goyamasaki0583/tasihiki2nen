<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ワンちゃんのおへやづくり：２年生のたし算ひっ算</title>
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Google Fonts (Kiwi Maru) -->
    <link href="https://fonts.googleapis.com/css2?family=Kiwi+Maru:wght@500;700&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Kiwi Maru', serif;
        }
        /* ふわふわ揺れるアニメーション */
        @keyframes float {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-10px); }
        }
        .float-anim {
            animation: float 2.5s ease-in-out infinite;
        }
        /* 跳ねるアニメーション */
        @keyframes bounce-custom {
            0%, 100% { transform: translateY(0) scale(1); }
            50% { transform: translateY(-25px) scale(1.15); }
        }
        .bounce-anim {
            animation: bounce-custom 0.5s ease-in-out 3;
        }
        /* ゆらゆら喜ぶアニメーション */
        @keyframes happy-dance {
            0%, 100% { transform: rotate(0deg) scale(1); }
            25% { transform: rotate(-10deg) scale(1.1); }
            75% { transform: rotate(10deg) scale(1.1); }
        }
        .happy-dance-anim {
            animation: happy-dance 0.4s ease-in-out infinite;
        }
        /* 間違えたときなどのブルブル */
        @keyframes shake {
            0%, 100% { transform: translateX(0); }
            25% { transform: translateX(-8px); }
            75% { transform: translateX(8px); }
        }
        .shake-anim {
            animation: shake 0.15s ease-in-out 2;
        }
    </style>
</head>
<body class="bg-gradient-to-b from-amber-50 to-orange-100 min-h-screen flex flex-col items-center justify-between p-4 overflow-x-hidden">

    <!-- ヘッダー -->
    <header class="w-full max-w-md bg-white/90 backdrop-blur shadow-md rounded-2xl p-4 text-center border-b-4 border-orange-400 mt-2">
        <h1 class="text-2xl font-bold text-orange-700">🐶 いぬのおへやづくり 🏠</h1>
        <p class="text-xs text-gray-600 mt-1">ひっ算にせいかいして、おへやを ごうかに しよう！</p>
    </header>

    <!-- メインコンテンツ -->
    <main class="w-full max-w-md flex-grow flex flex-col justify-center my-4">
        
        <!-- ゲーム開始前の設定画面 -->
        <div id="start-screen" class="bg-white rounded-3xl p-6 shadow-xl border-4 border-orange-300 text-center">
            <div class="text-7xl my-4 float-anim">🐾</div>
            <h2 class="text-xl font-bold text-gray-800 mb-2">もんだいのレベルを えらぼう！</h2>
            <p class="text-sm text-gray-600 mb-6">ぜんぶで 10もん あるよ！</p>
            <div class="space-y-4">
                <button onclick="startGame('easy')" class="w-full bg-green-400 hover:bg-green-500 text-white font-bold py-4 px-6 rounded-2xl border-b-4 border-green-600 active:border-b-0 active:translate-y-1 transition-all text-lg text-shadow">
                    🟢 くりあがり なし (やさしい)
                </button>
                <button onclick="startGame('hard')" class="w-full bg-orange-400 hover:bg-orange-500 text-white font-bold py-4 px-6 rounded-2xl border-b-4 border-orange-600 active:border-b-0 active:translate-y-1 transition-all text-lg text-shadow">
                    🟠 くりあがり あり (むずかしい)
                </button>
                <button onclick="startGame('random')" class="w-full bg-pink-400 hover:bg-pink-500 text-white font-bold py-4 px-6 rounded-2xl border-b-4 border-pink-600 active:border-b-0 active:translate-y-1 transition-all text-lg text-shadow">
                    ⚡ ランダム (まぜまぜ)
                </button>
            </div>
            <p class="text-xs text-gray-500 mt-6">※ 3けた（100の くらい）に なる もんだいは でないよ！</p>
        </div>

        <!-- メインゲーム画面 -->
        <div id="game-screen" class="hidden flex flex-col gap-4">
            
            <!-- ワンちゃんのお部屋表示エリア (お部屋を大きく拡張) -->
            <div class="bg-white/90 rounded-2xl p-4 shadow-md border-2 border-orange-200">
                <!-- 進行状況 -->
                <div class="flex justify-between items-center text-sm font-bold text-gray-700 mb-2">
                    <span id="question-number" class="bg-orange-100 text-orange-800 px-3 py-1 rounded-full">だい 1 / 10 もん</span>
                    <span id="score-display" class="text-orange-600 font-bold">ゲットした家具: 0こ</span>
                </div>
                
                <!-- お部屋グラフィック (高さをh-64へ拡張、家具サイズをtext-6xl〜text-7xlに巨大化) -->
                <div class="relative w-full h-64 bg-amber-50 rounded-xl border-2 border-amber-300 overflow-hidden shadow-inner flex items-end justify-center pb-2">
                    <!-- 壁と床のグラデーション境界 -->
                    <div class="absolute inset-x-0 bottom-0 h-1/4 bg-orange-100 border-t-2 border-orange-200"></div>
                    
                    <!-- 巨大化家具アイテム10個 -->
                    <!-- 1つ目: ベッド -->
                    <div id="item-1" class="absolute bottom-2 left-2 text-7xl opacity-10 transition-all duration-500 transform scale-75" title="ふかふかベッド">🛏️</div>
                    <!-- 2つ目: おやつ -->
                    <div id="item-2" class="absolute bottom-1 left-28 text-5xl opacity-10 transition-all duration-500 transform scale-75" title="おいしいほね">🦴</div>
                    <!-- 3つ目: ごはん -->
                    <div id="item-3" class="absolute bottom-1 right-28 text-5xl opacity-10 transition-all duration-500 transform scale-75" title="ごはんセット">🥣</div>
                    <!-- 4つ目: クマのぬいぐるみ -->
                    <div id="item-4" class="absolute bottom-2 right-2 text-6xl opacity-10 transition-all duration-500 transform scale-75" title="おもちゃのくま">🧸</div>
                    <!-- 5つ目: 明るい窓 -->
                    <div id="item-5" class="absolute top-2 left-4 text-7xl opacity-10 transition-all duration-500 transform scale-75" title="きれいなまど">🪟</div>
                    <!-- 6つ目: ボール -->
                    <div id="item-6" class="absolute bottom-1 left-48 text-5xl opacity-10 transition-all duration-500 transform scale-75" title="おもちゃのボール">🎾</div>
                    <!-- 7つ目: 観葉植物 -->
                    <div id="item-7" class="absolute bottom-16 left-2 text-6xl opacity-10 transition-all duration-500 transform scale-75" title="みどりのしょくぶつ">🪴</div>
                    <!-- 8つ目: ソファ -->
                    <div id="item-8" class="absolute bottom-16 right-2 text-6xl opacity-10 transition-all duration-500 transform scale-75" title="すてきなソファ">🛋️</div>
                    <!-- 9つ目: 絵画 -->
                    <div id="item-9" class="absolute top-2 right-4 text-6xl opacity-10 transition-all duration-500 transform scale-75" title="かべのえ">🖼️</div>
                    <!-- 10つ目: バルーン -->
                    <div id="item-10" class="absolute top-1 left-44 text-6xl opacity-10 transition-all duration-500 transform scale-75" title="カラフルバルーン">🎈</div>

                    <!-- エフェクトテキスト -->
                    <div id="room-effect" class="absolute inset-0 pointer-events-none flex items-center justify-center text-3xl font-bold hidden z-20"></div>

                    <!-- 主役のワンちゃん -->
                    <div id="dog-container" class="relative z-10 flex flex-col items-center mb-1">
                        <!-- 吹き出しヒント (やりなおしタイム等で表示) -->
                        <div id="dog-balloon" class="absolute bottom-20 bg-white border-2 border-orange-400 text-gray-800 text-xs rounded-xl p-2.5 shadow-md w-44 text-center hidden after:content-[''] after:absolute after:top-full after:left-1/2 after:-ml-2 after:border-8 after:border-transparent after:border-t-white before:content-[''] before:absolute before:top-full before:left-1/2 before:-ml-2.5 before:border-[10px] before:border-transparent before:border-t-orange-400">
                            <span id="balloon-text">まずは 〇＋〇をしよう！</span>
                        </div>
                        <div id="dog-emoji" class="text-7xl float-anim transition-transform duration-300">🐶</div>
                        <span id="dog-status" class="text-xs font-bold bg-orange-100 text-orange-700 px-2.5 py-0.5 rounded-full mt-1 shadow-sm">ココアちゃん</span>
                    </div>
                </div>
            </div>

            <!-- 【通常・復習】ひっ算入力ボード -->
            <div id="calc-board" class="bg-yellow-50 rounded-3xl p-6 shadow-xl border-4 border-yellow-400 relative">
                
                <!-- ひっ算エリア -->
                <div class="flex flex-col items-center my-2">
                    <div class="relative w-48 text-right font-mono text-4xl font-bold tracking-widest text-gray-800">
                        
                        <!-- くりあがりメモ (10の位の上) -->
                        <div class="flex justify-end w-full pr-14 mb-1 h-8">
                            <input type="text" id="carry-input" maxlength="1" placeholder=" "
                                class="w-8 h-8 text-center text-sm bg-yellow-200 border-2 border-dashed border-yellow-500 rounded text-red-500 focus:outline-none focus:bg-yellow-300" 
                                title="くりあがりのメモ（まちがってもせいかいにひびきません）">
                        </div>

                        <!-- 1つ目の数 -->
                        <div class="flex justify-end pr-4 mb-2">
                            <span id="num1-10" class="w-8 text-center">3</span>
                            <span id="num1-1" class="w-8 text-center">5</span>
                        </div>

                        <!-- 演算子と2つ目の数 -->
                        <div class="flex justify-between items-center pr-4 mb-2 border-b-4 border-gray-800 pb-2">
                            <span class="text-3xl font-bold text-orange-600 pl-2">＋</span>
                            <div class="flex">
                                <span id="num2-10" class="w-8 text-center">2</span>
                                <span id="num2-1" class="w-8 text-center">4</span>
                            </div>
                        </div>

                        <!-- 回答入力エリア (1の位から入力するフォーカス順) -->
                        <div class="flex justify-end pr-4 mt-3">
                            <!-- 10の位 -->
                            <input type="number" id="ans-10" min="0" max="9" pattern="[0-9]*" inputmode="numeric"
                                class="w-10 h-14 text-center border-2 border-orange-400 rounded-lg bg-white focus:ring-4 focus:ring-orange-300 focus:outline-none focus:border-orange-600 text-4xl"
                                onkeyup="moveFocus('ans-10', 'submit-btn')">
                            <!-- 1の位 (ここが一番最初にアクティブになります) -->
                            <input type="number" id="ans-1" min="0" max="9" pattern="[0-9]*" inputmode="numeric"
                                class="w-10 h-14 text-center border-2 border-orange-400 rounded-lg bg-white focus:ring-4 focus:ring-orange-300 focus:outline-none focus:border-orange-600 text-4xl ml-2"
                                onkeyup="moveFocus('ans-1', 'ans-10')">
                        </div>

                    </div>
                </div>

                <!-- 案内・ヒント誘導 -->
                <div class="text-center mt-4">
                    <p id="calc-hint-msg" class="text-xs text-gray-500">※ くりあがりがあるときは、ちいさいしかくに 「1」 をかくとわかりやすいよ！</p>
                </div>

                <!-- 判定アクション -->
                <div class="mt-6">
                    <button id="submit-btn" onclick="checkAnswer()" class="w-full bg-orange-500 hover:bg-orange-600 text-white font-bold py-3 px-6 rounded-2xl border-b-4 border-orange-700 active:border-b-0 active:translate-y-1 transition-all text-lg">
                        できた！あわせる
                    </button>
                </div>
            </div>

            <!-- 【全問正解限定】文章問題エリア -->
            <div id="word-problem-board" class="bg-emerald-50 rounded-3xl p-6 shadow-xl border-4 border-emerald-400 relative hidden">
                <div class="bg-white rounded-2xl p-4 border-2 border-emerald-200 mb-4 shadow-sm">
                    <span class="bg-emerald-100 text-emerald-800 text-xs font-bold px-2.5 py-1 rounded-full mb-2 inline-block">✨ スペシャルチャレンジ ✨</span>
                    <p id="word-problem-text" class="text-base font-bold text-gray-800 leading-relaxed">
                        ここに文章問題が表示されます。
                    </p>
                </div>

                <div class="flex flex-col items-center gap-3">
                    <label class="text-sm font-bold text-gray-600">こたえ (数字だけ にゅうりょくしてね)</label>
                    <div class="flex items-center gap-2">
                        <input type="number" id="word-ans" min="1" max="99" pattern="[0-9]*" inputmode="numeric"
                            class="w-24 h-14 text-center border-2 border-emerald-400 rounded-xl bg-white focus:ring-4 focus:ring-emerald-300 focus:outline-none text-3xl font-bold font-mono">
                        <span class="text-xl font-bold text-gray-700">にん (または こ/ひき)</span>
                    </div>
                </div>

                <div class="mt-6">
                    <button onclick="checkWordAnswer()" class="w-full bg-emerald-500 hover:bg-emerald-600 text-white font-bold py-3 px-6 rounded-2xl border-b-4 border-emerald-700 active:border-b-0 active:translate-y-1 transition-all text-lg">
                        こたえあわせをする！
                    </button>
                </div>
            </div>

            <!-- 戻るボタン -->
            <button onclick="returnToMenu()" class="text-center text-sm text-gray-600 hover:text-gray-900 underline">
                もどる
            </button>
        </div>

        <!-- 結果画面 -->
        <div id="result-screen" class="hidden bg-white rounded-3xl p-6 shadow-xl border-4 border-orange-400 text-center">
            <h2 class="text-2xl font-bold text-orange-700 mb-1" id="result-title">おへやが かんせいしたよ！</h2>
            <p class="text-sm text-gray-600 mb-4" id="result-score">10この家具をゲット！</p>
            
            <!-- 完成したお部屋のミニチュア -->
            <div class="relative w-full h-52 bg-amber-50 rounded-xl border-2 border-amber-300 overflow-hidden shadow-inner flex items-end justify-center pb-2 mb-6">
                <div class="absolute inset-x-0 bottom-0 h-1/3 bg-orange-100 border-t-2 border-orange-200"></div>
                
                <!-- 結果用アイテム -->
                <div id="res-item-1" class="absolute bottom-2 left-2 text-6xl opacity-10">🛏️</div>
                <div id="res-item-2" class="absolute bottom-1 left-24 text-4xl opacity-10">🦴</div>
                <div id="res-item-3" class="absolute bottom-1 right-24 text-4xl opacity-10">🥣</div>
                <div id="res-item-4" class="absolute bottom-2 right-2 text-5xl opacity-10">🧸</div>
                <div id="res-item-5" class="absolute top-2 left-4 text-6xl opacity-10">🪟</div>
                <div id="res-item-6" class="absolute bottom-1 left-40 text-4xl opacity-10">🎾</div>
                <div id="res-item-7" class="absolute bottom-14 left-2 text-5xl opacity-10">🪴</div>
                <div id="res-item-8" class="absolute bottom-14 right-2 text-5xl opacity-10">🛋️</div>
                <div id="res-item-9" class="absolute top-2 right-4 text-5xl opacity-10">🖼️</div>
                <div id="res-item-10" class="absolute top-1 left-36 text-5xl opacity-10">🎈</div>

                <div class="relative z-10 flex flex-col items-center mb-1">
                    <div id="res-dog-emoji" class="text-6xl float-anim">🐶</div>
                    <span class="text-xs font-bold bg-orange-100 text-orange-700 px-2.5 py-0.5 rounded-full mt-1">ココアちゃん</span>
                </div>
            </div>

            <p id="result-message" class="text-gray-700 mb-6 font-bold whitespace-pre-line"></p>
            
            <button onclick="returnToMenu()" class="w-full bg-orange-500 hover:bg-orange-600 text-white font-bold py-4 px-6 rounded-2xl border-b-4 border-orange-700 active:border-b-0 active:translate-y-1 transition-all text-lg">
                もういちど あそぶ
            </button>
        </div>

    </main>

    <!-- メッセージボックス (カスタムアラート) -->
    <div id="msg-box" class="fixed inset-0 bg-black/50 flex items-center justify-center p-4 z-50 hidden">
        <div class="bg-white rounded-2xl p-6 max-w-sm w-full text-center border-4 border-orange-500 shadow-2xl">
            <div id="msg-emoji" class="text-5xl mb-2">💡</div>
            <p id="msg-text" class="text-lg font-bold text-gray-800 mb-4 whitespace-pre-line"></p>
            <button onclick="closeMsgBox()" class="bg-orange-500 hover:bg-orange-600 text-white font-bold px-6 py-2.5 rounded-xl">
                OK
            </button>
        </div>
    </div>

    <!-- フッター -->
    <footer class="text-center text-xs text-orange-900/60 pb-2">
        &copy; ワンちゃんのおへやづくり 2ねんせい 算数ゲーム
    </footer>

    <!-- スクリプト -->
    <script>
        // ゲームステート
        let currentMode = 'easy';
        let currentQuestion = 1;
        const totalQuestions = 10;
        let score = 0;
        let num1 = 0;
        let num2 = 0;
        let correctAnswer = 0;

        // まちがえた問題を記録するリスト
        let incorrectQuestions = [];
        // やりなおし用のリスト（最大5問）
        let reviewQuestions = [];
        let reviewIndex = 0;
        let isReviewMode = false;

        // 文章問題のステート
        let isWordProblemMode = false;
        let wordProblemAnswer = 0;

        // 巨大家具の名称
        const itemNames = {
            1: '🛏️ ふかふかベッド',
            2: '🦴 おいしいおやつ',
            3: '🥣 なみなみごはん',
            4: '🧸 クマのぬいぐるみ',
            5: '🪟 あかるいまど',
            6: '🎾 はねるボール',
            7: '🪴 みどりのプランター',
            8: '🛋️ ゆったりソファ',
            9: '🖼️ かべのおしゃれな絵',
            10: '🎈 カラフルなふうせん'
        };

        // 吹き出し・ヒント表示関数
        function setDogBalloon(text, show = true) {
            const balloon = document.getElementById('dog-balloon');
            const balloonText = document.getElementById('balloon-text');
            if (show) {
                balloonText.innerText = text;
                balloon.classList.remove('hidden');
            } else {
                balloon.classList.add('hidden');
            }
        }

        // カスタムメッセージボックス
        function showMsg(text, emoji = '💡') {
            document.getElementById('msg-text').innerText = text;
            document.getElementById('msg-emoji').innerText = emoji;
            document.getElementById('msg-box').classList.remove('hidden');
        }

        function closeMsgBox() {
            document.getElementById('msg-box').classList.add('hidden');
        }

        // 入力フォーカスの移動
        function moveFocus(currentId, nextId) {
            const currentElement = document.getElementById(currentId);
            if (currentElement.value.length >= 1) {
                const nextElement = document.getElementById(nextId);
                if (nextElement) {
                    nextElement.focus();
                }
            }
        }

        // ゲームスタート
        function startGame(mode) {
            currentMode = mode;
            currentQuestion = 1;
            score = 0;
            incorrectQuestions = [];
            reviewQuestions = [];
            isReviewMode = false;
            isWordProblemMode = false;

            document.getElementById('start-screen').classList.add('hidden');
            document.getElementById('result-screen').classList.add('hidden');
            document.getElementById('game-screen').classList.remove('hidden');

            // レイアウト切り替え
            document.getElementById('calc-board').classList.remove('hidden');
            document.getElementById('word-problem-board').classList.add('hidden');

            setDogBalloon('', false);
            resetRoomVisuals();
            generateQuestion();
        }

        // 部屋のビジュアルをリセット
        function resetRoomVisuals() {
            for (let i = 1; i <= 10; i++) {
                const el = document.getElementById(`item-${i}`);
                if (el) {
                    el.classList.add('opacity-10', 'scale-75');
                    el.classList.remove('opacity-100', 'scale-100');
                }
            }
            document.getElementById('dog-emoji').innerText = '🐶';
            document.getElementById('dog-emoji').className = 'text-7xl float-anim';
            document.getElementById('score-display').innerText = `ゲットした家具: 0こ`;
        }

        // 家具のアンロック演出 (透明度10% ➔ 100%へ)
        function unlockItem(itemIndex) {
            const el = document.getElementById(`item-${itemIndex}`);
            if (el) {
                el.classList.remove('opacity-10', 'scale-75');
                el.classList.add('opacity-100', 'scale-100');
            }
            document.getElementById('score-display').innerText = `ゲットした家具: ${score}こ`;
        }

        // 問題の自動生成 (合計が99以下)
        function generateQuestion() {
            document.getElementById('ans-10').value = '';
            document.getElementById('ans-1').value = '';
            document.getElementById('carry-input').value = '';
            
            // 💡 1の位にフォーカスをあてる
            document.getElementById('ans-1').focus();

            // ワンちゃんの顔をニュートラルに戻す
            document.getElementById('dog-emoji').innerText = '🐶';
            setDogBalloon('', false);

            document.getElementById('question-number').innerText = `だい ${currentQuestion} / ${totalQuestions} もん`;

            let n1 = 0;
            let n2 = 0;
            let sum = 0;

            let modeToApply = currentMode;
            if (currentMode === 'random') {
                modeToApply = Math.random() > 0.5 ? 'easy' : 'hard';
            }

            let attempts = 0;
            while (attempts < 100) {
                n1 = Math.floor(Math.random() * 80) + 10; // 10〜89
                n2 = Math.floor(Math.random() * 80) + 9;  // 9〜89

                sum = n1 + n2;

                if (sum > 99) {
                    continue; 
                }

                const n1_ones = n1 % 10;
                const n2_ones = n2 % 10;
                const isCarry = (n1_ones + n2_ones) >= 10;

                if (modeToApply === 'easy' && !isCarry) {
                    break;
                } else if (modeToApply === 'hard' && isCarry) {
                    break;
                }
                attempts++;
            }

            if (sum > 99 || sum < 10) {
                n1 = 34; n2 = 25; sum = 59;
            }

            num1 = n1;
            num2 = n2;
            correctAnswer = sum;

            // 盤面への反映
            const n1_10 = Math.floor(n1 / 10);
            const n1_1 = n1 % 10;
            const n2_10 = Math.floor(n2 / 10);
            const n2_1 = n2 % 10;

            document.getElementById('num1-10').innerText = n1_10 > 0 ? n1_10 : '';
            document.getElementById('num1-1').innerText = n1_1;
            document.getElementById('num2-10').innerText = n2_10 > 0 ? n2_10 : '';
            document.getElementById('num2-1').innerText = n2_1;
        }

        // やりなおし問題のロード
        function generateReviewQuestion(q) {
            document.getElementById('ans-10').value = '';
            document.getElementById('ans-1').value = '';
            document.getElementById('carry-input').value = '';
            document.getElementById('ans-1').focus();

            num1 = q.n1;
            num2 = q.n2;
            correctAnswer = q.ans;

            const n1_10 = Math.floor(num1 / 10);
            const n1_1 = num1 % 10;
            const n2_10 = Math.floor(num2 / 10);
            const n2_1 = num2 % 10;

            document.getElementById('num1-10').innerText = n1_10 > 0 ? n1_10 : '';
            document.getElementById('num1-1').innerText = n1_1;
            document.getElementById('num2-10').innerText = n2_10 > 0 ? n2_10 : '';
            document.getElementById('num2-1').innerText = n2_1;

            // コメントの自動生成
            const hintText = `まずは 1のくらいの 「${n1_1} ＋ ${n2_1}」を しよう！`;
            setDogBalloon(hintText, true);
        }

        // 回答判定
        function checkAnswer() {
            const ans10Val = document.getElementById('ans-10').value;
            const ans1Val = document.getElementById('ans-1').value;

            if (ans1Val === '') {
                showMsg('1の くらいを にゅうりょくしてね！', '✏️');
                return;
            }

            const tens = ans10Val === '' ? 0 : parseInt(ans10Val, 10);
            const ones = parseInt(ans1Val, 10);
            const userAnswer = (tens * 10) + ones;

            const dogContainer = document.getElementById('dog-container');
            const dogEmoji = document.getElementById('dog-emoji');
            const effect = document.getElementById('room-effect');

            if (userAnswer === correctAnswer) {
                // 正解！
                dogEmoji.innerText = '😍';
                dogContainer.classList.add('bounce-anim');
                
                effect.innerText = isReviewMode ? '✨バッチリ！✨' : '✨家具ゲット！✨';
                effect.className = "absolute inset-0 pointer-events-none flex items-center justify-center text-3xl font-bold text-orange-600 bg-orange-100/40 z-20";
                effect.classList.remove('hidden');

                if (!isReviewMode) {
                    score++;
                    unlockItem(score);
                }
                
                setTimeout(() => {
                    dogContainer.classList.remove('bounce-anim');
                    effect.classList.add('hidden');
                    
                    if (isReviewMode) {
                        showMsg('すごい！かんぺきな ひっ算に なったね！', '🌟');
                        nextStep();
                    } else {
                        const unlockedName = itemNames[score];
                        showMsg(`せいかい！ 🎉\nおへやに 「${unlockedName}」 が ふえたよ！`, '🎁');
                        nextStep();
                    }
                }, 1200);

            } else {
                // 不正解
                dogEmoji.innerText = '🥺';
                
                // もし通常モードなら、やりなおしリストに追加
                if (!isReviewMode) {
                    const alreadySaved = incorrectQuestions.some(q => q.n1 === num1 && q.n2 === num2);
                    if (!alreadySaved) {
                        incorrectQuestions.push({ n1: num1, n2: num2, ans: correctAnswer });
                    }
                }

                // ゆらす
                dogContainer.style.animation = 'shake 0.3s ease-in-out 2';

                setTimeout(() => {
                    dogContainer.style.animation = '';
                    
                    const correctOnes = (num1 % 10) + (num2 % 10);
                    let advice = `おしい！もういちど 計算してみよう。\n\n`;
                    if (correctOnes >= 10) {
                        advice += `【ヒント💡】\n1のくらいの 「${num1 % 10} ＋ ${num2 % 10} ＝ ${correctOnes}」 は、10をこえるから、10のくらいに 「1」 を くりあげるよ！`;
                    } else {
                        advice += `【ヒント💡】\n1のくらいは 「${num1 % 10} ＋ ${num2 % 10}」。\n10のくらいは 「${Math.floor(num1/10)} ＋ ${Math.floor(num2/10)}」 をたしてね。`;
                    }
                    showMsg(advice, '🐶');
                }, 600);
            }
        }

        // 文章問題の開始 (全問正解者限定)
        function startWordProblem() {
            isWordProblemMode = true;
            document.getElementById('calc-board').classList.add('hidden');
            document.getElementById('word-problem-board').classList.remove('hidden');
            document.getElementById('question-number').innerText = `✨ さいごの とくべつもんだい ✨`;
            
            const problems = [
                {
                    text: "ココアちゃんは、きのう ほねを 36こ ひろいました。きょうは ほねを 25こ ひろいました。あわせて なんこ ひろったかな？",
                    n1: 36, n2: 25, ans: 61, unit: "こ"
                },
                {
                    text: "いぬのひろばに 白いワンちゃんが 28ひき、茶いろいワンちゃんが 19ひき あそんでいます。ぜんぶで なんびき いるかな？",
                    n1: 28, n2: 19, ans: 47, unit: "ひき"
                },
                {
                    text: "ココアちゃんは、おさんぽで てんともうしを 14ひき、ちょうちょを 27ひき みつけました。あわせて なんびき みつけたかな？",
                    n1: 14, n2: 27, ans: 41, unit: "ひき"
                }
            ];

            const selected = problems[Math.floor(Math.random() * problems.length)];
            document.getElementById('word-problem-text').innerText = selected.text;
            wordProblemAnswer = selected.ans;
            document.getElementById('word-ans').value = '';
            document.getElementById('word-ans').focus();

            setDogBalloon('さいごの むずかしい もんだいだよ！がんばって！', true);
        }

        // 文章問題の判定
        function checkWordAnswer() {
            const userAnsVal = document.getElementById('word-ans').value;
            if (userAnsVal === '') {
                showMsg('こたえを にゅうりょくしてね！', '✏️');
                return;
            }

            const userAns = parseInt(userAnsVal, 10);
            const dogEmoji = document.getElementById('dog-emoji');
            const dogContainer = document.getElementById('dog-container');

            if (userAns === wordProblemAnswer) {
                // 超大喜び
                dogEmoji.innerText = '💖🐶💖';
                dogEmoji.className = 'text-7xl happy-dance-anim';
                
                showMsg('すごーーーい！大せいかい！！ 🎉✨\nワンちゃんが うれしくて、ダンスをして よろこんでいるよ！', '🎉');
                
                setTimeout(() => {
                    endGame(true);
                }, 2000);
            } else {
                dogEmoji.innerText = '🥺';
                showMsg('おしい！もういちど よくよんで 計算してみよう。', '💡');
            }
        }

        // やりなおし（復習）フェーズの開始
        function startReviewPhase() {
            isReviewMode = true;
            reviewIndex = 0;

            const shuffled = [...incorrectQuestions].sort(() => 0.5 - Math.random());
            reviewQuestions = shuffled.slice(0, 5);

            showMsg(`10問おわったよ！\nまちがえた ${reviewQuestions.length}問 に もういちど チャレンジしてみよう！`, '🐾');

            loadReviewQuestion();
        }

        function loadReviewQuestion() {
            document.getElementById('question-number').innerText = `やりなおし ${reviewIndex + 1} / ${reviewQuestions.length} もん`;
            generateReviewQuestion(reviewQuestions[reviewIndex]);
        }

        // 次のステップ
        function nextStep() {
            if (isReviewMode) {
                reviewIndex++;
                if (reviewIndex < reviewQuestions.length) {
                    loadReviewQuestion();
                } else {
                    endGame(false);
                }
                return;
            }

            currentQuestion++;
            if (currentQuestion > totalQuestions) {
                if (score === 10) {
                    startWordProblem();
                } else {
                    if (incorrectQuestions.length > 0) {
                        startReviewPhase();
                    } else {
                        endGame(false);
                    }
                }
            } else {
                generateQuestion();
            }
        }

        // ゲームの終了画面
        function endGame(clearedWordProblem = false) {
            document.getElementById('game-screen').classList.add('hidden');
            document.getElementById('result-screen').classList.remove('hidden');

            const resDog = document.getElementById('res-dog-emoji');
            resDog.className = 'text-6xl float-anim';

            document.getElementById('result-score').innerText = `ゲットした家具: ${score} / 10こ`;

            // 結果ミニチュアのビジュアル設定
            for (let i = 1; i <= 10; i++) {
                const resEl = document.getElementById(`res-item-${i}`);
                if (resEl) {
                    if (i <= score) {
                        resEl.classList.remove('opacity-10');
                        resEl.classList.add('opacity-100');
                    } else {
                        resEl.classList.remove('opacity-100');
                        resEl.classList.add('opacity-10');
                    }
                }
            }

            const title = document.getElementById('result-title');
            const msg = document.getElementById('result-message');

            if (clearedWordProblem) {
                title.innerText = "👑 ワンちゃんマスター誕生！ 👑";
                resDog.innerText = '💖🐶💖';
                resDog.className = 'text-6xl happy-dance-anim';
                msg.innerText = "すごい！10問のひっ算をぜんぶ正解して、おまけのむずかしい文章問題も大正解！\nワンちゃんは今、あなたのおかげで世界一しあわせです！";
            } else if (score === 10) {
                title.innerText = "👑 かんぺき！超デラックスルーム！ 👑";
                resDog.innerText = '😍';
                msg.innerText = "すごすぎる！ 10問ぜんぶに正解したよ！\nおまけの文章問題は、次はクリアできるようにがんばろう！";
            } else if (score >= 7) {
                title.innerText = "✨ すてきなお部屋ができたよ！ ✨";
                resDog.innerText = '✨🐶✨';
                msg.innerText = `${score}こも 家具をゲットできたね！\nやりなおしタイムもがんばって、ひっ算が得意になったよ。`;
            } else if (score >= 4) {
                title.innerText = "👍 かわいいお部屋になったね！ 👍";
                resDog.innerText = '🐕';
                msg.innerText = `たくさんの計算、最後までがんばったね！\nやり直したことで、くりあがりのコツがつかめてきたよ！`;
            } else {
                title.innerText = "🐾 次こそがんばろう！ 🐾";
                resDog.innerText = '🐶';
                msg.innerText = "いっしょに練習してくれてありがとう！\nいつでも何度でも、お部屋づくりを楽しみにきてね。";
            }
        }

        // メニューに戻る
        function returnToMenu() {
            document.getElementById('game-screen').classList.add('hidden');
            document.getElementById('result-screen').classList.add('hidden');
            document.getElementById('start-screen').classList.remove('hidden');
        }
    </script>
</body>
</html>
